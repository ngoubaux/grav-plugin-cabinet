{# ── Page de préparation de séance ────────────────────────────────────────────
   Le contenu est défini par chaque praticien dans Cabinet → Paramètres → Page accueil.
   Les valeurs {{variable}} sont substituées côté serveur par ClientObject::getPrepPageContent().
   Si aucun contenu n'est défini, un rendu par défaut basé sur les données praticien s'affiche.
   ──────────────────────────────────────────────────────────────────────────── #}
{% set p    = object.practitionerConfig %}
{% set body = object.prepPageContent %}

{% set pract_name    = p.practitioner_name    ?: (grav.config.site.author.name ?: '') %}
{% set pract_title   = p.practitioner_title   ?: '' %}
{% set pract_phone   = p.practitioner_phone   ?: '' %}
{% set pract_website = p.practitioner_website ?: '' %}
{% set pract_booking = p.practitioner_booking_url ?: '' %}
{% set pract_footer  = p.prep_page_footer ?: "Cette approche d'accompagnement ne se substitue pas à un traitement médical." %}
<div class="email-container">
    <div class="header">
        <h1>Bienvenue chez {{ pract_name|e }}</h1>
        {% if pract_title %}<p>{{ pract_title|e }}</p>{% endif %}
    </div>

    <div class="content">
        {# ── Contenu personnalisé (Markdown + variables substituées) ── #}
        {% if body %}

            {{ body|markdown }}

        {# ── Contenu par défaut si aucune page personnalisée n'est configurée ── #}
        {% else %}
            {% set rendez_vous      = object.nextAppointment %}
            {% set next_visit_date  = rendez_vous ? rendez_vous.appointment_date : null %}
            {% set next_visit_time  = rendez_vous ? rendez_vous.appointment_hour : null %}
            {% set pract_street  = p.practitioner_address_street  ?: '' %}
            {% set pract_details = p.practitioner_address_details ?: '' %}
            {% set pract_city    = p.practitioner_address_city    ?: '' %}
            {% set pract_code    = p.practitioner_access_code     ?: '' %}
            {% set pract_price   = p.practitioner_first_session_price ?: '75' %}

            {% set rdv_type = 'shiatsu sur futon' %}
            {% if rendez_vous %}
                {% if rendez_vous.appointment_type == "seance_échange" %}
                    {% set rdv_type = "séance d'échange" %}
                {% elseif rendez_vous.appointment_type == "shiatsu_chair" %}
                    {% set rdv_type = "shiatsu sur chaise" %}
                {% endif %}
            {% endif %}
            <p class="greeting">Bonjour {{ object.first_name|e }},</p>

            {% if rendez_vous %}
            <p>Je suis ravi de vous accueillir pour votre prochaine séance de {{ rdv_type }} le
            <strong>{{ 'GRAV.DAYS_OF_THE_WEEK'|ta(next_visit_date|date('N') - 1)|e }} {{ next_visit_date|date("d") }} {{ 'GRAV.MONTHS_OF_THE_YEAR'|ta(next_visit_date|date('n') - 1)|e }}</strong>
            à <strong>{{ next_visit_time }}</strong>.</p>
            {% else %}
            <p><em>Vous n'avez pas encore de prochain rendez-vous planifié.</em></p>
            {% if pract_booking %}<p><a href="{{ pract_booking|e }}" style="display:inline-block;padding:10px 20px;background-color:#4a7c59;color:#fff;text-decoration:none;border-radius:5px;font-weight:bold;">📅 Prendre un rendez-vous</a></p>{% endif %}
            {% endif %}

            {% if pract_street %}
            <h2>📍 Informations pratiques</h2>
            <div class="info-box">
                <h3>Adresse</h3>
                <p><strong>{{ pract_street|e }}</strong><br>{% if pract_details %}{{ pract_details|e }}<br>{% endif %}{{ pract_city|e }}</p>
            </div>
            {% if pract_code %}<p>Code d'accès : <span class="code-access">{{ pract_code|e }}</span></p>{% endif %}
            {% endif %}

            {% if rendez_vous %}
            <h2>✨ Votre première séance</h2>
            <div class="price-highlight">
                {% if object.tags is defined and 'Echange' in object.tags %}
                    Vous avez choisi une séance d'échange.
                {% else %}
                    Séance de <strong>{{ rendez_vous.duration_minutes }} min</strong> au tarif de <strong>{{ pract_price|e }}€</strong>.
                {% endif %}
            </div>
            {% endif %}

            <div class="contact-info">
                <p><strong>💬 Pour toute question</strong></p>
                <p>
                    {% if pract_phone %}📞 <a href="tel:{{ pract_phone|e }}">{{ pract_phone|e }}</a><br>{% endif %}
                    {% if pract_website %}🌐 <a href="{{ pract_website|e }}">{{ pract_website|replace({'https://': '', 'http://': ''})|e }}</a><br>{% endif %}
                    {% if pract_booking %}📅 <a href="{{ pract_booking|e }}">Prendre un rendez-vous</a>{% endif %}
                </p>
            </div>

            <div class="signature">
                <p>Au plaisir de vous rencontrer,</p>
                <strong>{{ pract_name|e }}</strong>
                {% if pract_title %}<p style="font-size:14px">{{ pract_title|e }}</p>{% endif %}
            </div>
        {% endif %}

    </div>

    <div class="footer">{{ pract_footer|e }}</div>
    {{ pract }}
</div>
