<div x-show="$store.cab.activeTab==='fiche'">

  {# ── Barre d'action ── #}
  <div class="flex items-center justify-between mb-4">
    <span class="text-[10px] text-zinc-400 dark:text-zinc-500 font-mono select-all"
          x-text="$store.cab.activeId"></span>
    <a class="inline-flex items-center gap-1.5 text-[12px] no-underline border border-zinc-200 dark:border-zinc-700 rounded-lg px-3 py-1.5 transition-colors hover:text-primary hover:border-primary hover:bg-[color-mix(in_srgb,var(--color-primary)_5%,transparent)]"
       :class="$store.cab.activeClientPageUrl !== '/preparons-votre-visite'
         ? 'text-zinc-600 dark:text-zinc-300'
         : 'text-zinc-400 dark:text-zinc-500 pointer-events-none opacity-50'"
       :href="$store.cab.activeClientPageUrl"
       target="_blank" rel="noopener">
      🔗 Ouvrir la page client
    </a>
  </div>

  {# ── Stats ── #}
  <div class="grid grid-cols-4 gap-2.5 mb-5 max-md:grid-cols-2">
    <div class="bg-zinc-100 dark:bg-zinc-800 rounded-[10px] pt-3.5 px-2.5 pb-2.5 text-center border border-zinc-200 dark:border-zinc-700 transition-shadow hover:shadow-md">
      <div class="text-[16px] mb-1 opacity-70">📋</div>
      <div class="text-lg font-semibold text-primary leading-tight" x-text="$store.cab.activeSessionCount"></div>
      <div class="text-[10px] text-zinc-500 dark:text-zinc-400 mt-0.5 uppercase tracking-[.4px]">Séances</div>
    </div>
    <div class="bg-zinc-100 dark:bg-zinc-800 rounded-[10px] pt-3.5 px-2.5 pb-2.5 text-center border border-zinc-200 dark:border-zinc-700 transition-shadow hover:shadow-md">
      <div class="text-[16px] mb-1 opacity-70">🕐</div>
      <div class="text-lg font-semibold text-primary leading-tight"
           x-text="$store.cab.lastSessionDate ? new Date($store.cab.lastSessionDate + 'T12:00').toLocaleDateString('fr-FR', {day:'numeric', month:'short'}) : '—'"></div>
      <div class="text-[10px] text-zinc-500 dark:text-zinc-400 mt-0.5 uppercase tracking-[.4px]">Dernière séance</div>
    </div>
    <div class="rounded-[10px] pt-3.5 px-2.5 pb-2.5 text-center border transition-shadow hover:shadow-md"
         :class="$store.cab.nextSessionLabel
           ? 'border-primary bg-[color-mix(in_srgb,var(--color-primary)_6%,var(--color-zinc-100))] dark:bg-[color-mix(in_srgb,var(--color-primary)_6%,var(--color-zinc-800))]'
           : 'bg-zinc-100 dark:bg-zinc-800 border-zinc-200 dark:border-zinc-700'">
      <div class="text-[16px] mb-1 opacity-70">📅</div>
      <div class="text-lg font-semibold text-primary leading-tight"
           x-text="$store.cab.nextSessionLabel || '—'"></div>
      <div class="text-[10px] text-zinc-500 dark:text-zinc-400 mt-0.5 uppercase tracking-[.4px]">Prochaine séance</div>
    </div>
    <div class="bg-zinc-100 dark:bg-zinc-800 rounded-[10px] pt-3.5 px-2.5 pb-2.5 text-center border border-zinc-200 dark:border-zinc-700 transition-shadow hover:shadow-md">
      <div class="text-[16px] mb-1 opacity-70">🗂️</div>
      <div class="text-lg font-semibold text-primary leading-tight"
           x-text="$store.cab.activeClient?.created ? new Date($store.cab.activeClient.created).toLocaleDateString('fr-FR', {day:'numeric', month:'short', year:'numeric'}) : '—'"></div>
      <div class="text-[10px] text-zinc-500 dark:text-zinc-400 mt-0.5 uppercase tracking-[.4px]">Dossier créé</div>
    </div>
  </div>

  <div class="section-label">Identité</div>
  <div class="field-grid">
    <div class="field"><label>Prénom</label><input x-model="$store.cab.activeClient.first_name"></div>
    <div class="field"><label>Nom</label><input x-model="$store.cab.activeClient.last_name"></div>
    <div class="field"><label>Date de naissance</label><input type="date" x-model="$store.cab.activeClient.ddn"></div>
    <div class="field"><label>Téléphone</label><input x-model="$store.cab.activeClient.phone"></div>
    <div class="field field-full"><label>Email</label><input x-model="$store.cab.activeClient.email"></div>
  </div>

  <div class="section-label">Motif &amp; contexte</div>
  <div class="field-grid">
    <div class="field field-full">
      <label>Motif de consultation</label>
      <input x-model="$store.cab.activeClient.motif">
    </div>
    <div class="field field-full">
      <label>Antécédents &amp; contexte de santé</label>
      <textarea x-model="$store.cab.activeClient.antecedents"></textarea>
    </div>
    <div class="field field-full">
      <label>Notes praticien (internes)</label>
      <textarea x-model="$store.cab.activeClient.notes"></textarea>
    </div>
  </div>

  <div class="btn-row">
    <button class="btn-save" @click="$store.cab.saveFiche()">Enregistrer</button>
    <button class="btn-ghost" @click="$store.cab.deleteClient()">Supprimer le dossier</button>
  </div>

</div>
