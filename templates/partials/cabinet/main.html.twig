<div class="main bg-white dark:bg-zinc-900 flex flex-col max-md:hidden" id="mainArea" x-data="cabinetMain">

  <div class="flex items-center px-3.5 h-[34px] border-b border-zinc-200 dark:border-zinc-700 bg-zinc-100 dark:bg-zinc-800 shrink-0 gap-[10px] text-[11px] text-zinc-500 dark:text-zinc-400 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
       x-data="{...cabinetStatusBar(), ...cabinetDriveBar()}">
    <div class="flex items-center gap-2 shrink-0">
      <span class="flex items-center gap-[5px] transition-colors"
            :class="$store.cab.queueCount > 0 ? 'text-primary font-semibold' : ''">
        <span class="w-1.5 h-1.5 rounded-full shrink-0 transition-[background-color]"
              :class="$store.cab.queueCount > 0 ? 'bg-primary animate-pulse' : 'bg-zinc-300 dark:bg-zinc-600'"></span>
        <span x-text="$store.cab.queueCount > 0 ? $store.cab.queueCount + ' SMS en attente' : 'File SMS vide'"></span>
      </span>
      <div class="w-px h-3.5 bg-zinc-200 dark:bg-zinc-700 shrink-0"></div>
      <span class="flex items-center gap-[5px] cursor-pointer shrink-0"
            @click="toggleDrive()" :title="statusLabel">
        <span class="w-[7px] h-[7px] rounded-full shrink-0"
              :class="{
                'bg-[#3B6D11]': statusState==='ok',
                'bg-[#BA7517] animate-pulse': statusState==='loading',
                'bg-primary': statusState==='error',
                'bg-zinc-300 dark:bg-zinc-600': statusState!=='ok' && statusState!=='loading' && statusState!=='error'
              }"></span>
        <span x-text="connected ? 'Drive' : 'Drive off'"></span>
      </span>
      <button class="bg-transparent border border-zinc-200 dark:border-zinc-700 rounded-[5px] px-1.5 py-[2px] text-[12px] cursor-pointer text-zinc-500 dark:text-zinc-400 leading-[1.5] font-[inherit] hover:text-primary hover:border-primary hover:bg-[color-mix(in_srgb,var(--color-primary)_5%,transparent)] transition-colors shrink-0"
              x-show="connected" @click="openVerif()" title="Vérifier Drive">✓</button>
    </div>
    <div class="flex-1"></div>
    <div class="flex items-center gap-2 shrink-0">
      <span class="whitespace-nowrap" x-text="Object.keys($store.cab.clients).length + ' clients'"></span>
      <div class="w-px h-3.5 bg-zinc-200 dark:bg-zinc-700 shrink-0"></div>
      <a class="inline-flex items-center gap-[3px] text-zinc-500 dark:text-zinc-400 no-underline px-[7px] py-[2px] rounded-[5px] border border-zinc-200 dark:border-zinc-700 leading-[1.5] whitespace-nowrap hover:text-primary hover:border-primary hover:bg-[color-mix(in_srgb,var(--color-primary)_5%,transparent)] transition-colors shrink-0"
         :href="gcalUrl" target="_blank" rel="noopener" title="Google Calendar">📅 Agenda</a>
      <template x-if="$store.cab.communicationSettings.googleReviewUrl">
        <a class="inline-flex items-center gap-[3px] text-zinc-500 dark:text-zinc-400 no-underline px-[7px] py-[2px] rounded-[5px] border border-zinc-200 dark:border-zinc-700 leading-[1.5] whitespace-nowrap hover:text-primary hover:border-primary hover:bg-[color-mix(in_srgb,var(--color-primary)_5%,transparent)] transition-colors shrink-0"
           :href="$store.cab.communicationSettings.googleReviewUrl"
           target="_blank" rel="noopener" title="Avis Google">⭐ Avis</a>
      </template>
      <button class="bg-transparent border border-zinc-200 dark:border-zinc-700 rounded-[5px] px-1.5 py-[2px] text-[12px] cursor-pointer leading-[1.5] font-[inherit] transition-colors shrink-0"
              :class="$store.cab.showDashboard
                ? 'text-primary border-primary bg-[color-mix(in_srgb,var(--color-primary)_8%,transparent)]'
                : 'text-zinc-500 dark:text-zinc-400 hover:text-primary hover:border-primary hover:bg-[color-mix(in_srgb,var(--color-primary)_5%,transparent)]'"
              @click="$store.cab.showDashboard ? ($store.cab.showDashboard=false) : $store.cab.openDashboard()"
              title="Tableau de bord">📊</button>
      <button class="bg-transparent border border-zinc-200 dark:border-zinc-700 rounded-[5px] px-1.5 py-[2px] text-[12px] cursor-pointer text-zinc-500 dark:text-zinc-400 leading-[1.5] font-[inherit] hover:text-primary hover:border-primary hover:bg-[color-mix(in_srgb,var(--color-primary)_5%,transparent)] transition-colors shrink-0"
              @click="$store.cab.openModal('settings')" title="Paramètres">⚙</button>
    </div>
  </div>

  {% include 'partials/cabinet/tab-aide.html.twig' %}
  {% include 'partials/cabinet/tab-dashboard.html.twig' %}

  <div class="flex-1 flex flex-col items-center justify-center text-zinc-500 dark:text-zinc-400 gap-2"
       x-show="!$store.cab.activeId && !$store.cab.showHelp && !$store.cab.showDashboard">
    <div class="w-10 h-10 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-lg">&#128100;</div>
    <span class="text-[13px]">Sélectionnez un client</span>
    <span class="text-xs text-zinc-400 dark:text-zinc-500">ou créez un nouveau dossier</span>
  </div>

  <template x-if="$store.cab.activeId && !$store.cab.showHelp && !$store.cab.showDashboard">
    <div class="flex flex-col flex-1 min-h-0">

      <div class="flex border-b border-zinc-200 dark:border-zinc-700 bg-zinc-100 dark:bg-zinc-800 overflow-x-auto max-md:[scrollbar-width:none] max-md:[&::-webkit-scrollbar]:hidden">
        <button class="hidden max-md:inline-flex items-center text-[13px] text-zinc-500 dark:text-zinc-400 cursor-pointer pl-3 pr-1 shrink-0 hover:text-zinc-700 dark:hover:text-zinc-200 leading-none"
                @click="$store.cab.goBack()" title="Retour">&#8592;</button>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='fiche' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('fiche')">Fiche client</div>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='seances' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('seances')">
          Séances (<span x-text="$store.cab.activeSessionCount"></span>)
        </div>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='bilan' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('bilan')">Bilan</div>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='communication' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('communication')">Communication</div>
      </div>

      <div class="flex-1 overflow-y-auto p-5 max-md:p-3.5">
        {% include 'partials/cabinet/tab-fiche.html.twig' %}
        {% include 'partials/cabinet/tab-seances.html.twig' %}
        {% include 'partials/cabinet/tab-bilan.html.twig' %}
        {% include 'partials/cabinet/tab-communication.html.twig' %}
      </div>

    </div>
  </template>

</div>
