<div class="main bg-white dark:bg-zinc-900 flex flex-col max-md:hidden" id="mainArea" x-data="cabinetMain">

  <div class="status-bar" x-data="{...cabinetStatusBar(), ...cabinetDriveBar()}">
    <div class="status-bar-left">
      <span class="status-queue" :class="$store.cab.queueCount > 0 ? 'status-queue--active' : ''">
        <span class="status-queue-dot" :class="$store.cab.queueCount > 0 ? 'active' : ''"></span>
        <span x-text="$store.cab.queueCount > 0 ? $store.cab.queueCount + ' SMS en attente' : 'File SMS vide'"></span>
      </span>
      <div class="status-sep"></div>
      <span class="status-drive" :class="statusState" @click="toggleDrive()" :title="statusLabel" style="cursor:pointer">
        <span class="drive-dot" :class="statusState"></span>
        <span x-text="connected ? 'Drive' : 'Drive off'"></span>
      </span>
      <button class="status-icon-btn" x-show="connected" @click="openVerif()" title="Vérifier Drive">✓</button>
    </div>
    <div class="status-bar-right">
      <span x-text="Object.keys($store.cab.clients).length + ' clients'"></span>
      <div class="status-sep"></div>
      <a class="status-link" :href="gcalUrl" target="_blank" rel="noopener" title="Google Calendar">📅 Agenda</a>
      <template x-if="$store.cab.communicationSettings.googleReviewUrl">
        <a class="status-link"
           :href="$store.cab.communicationSettings.googleReviewUrl"
           target="_blank" rel="noopener" title="Avis Google">⭐ Avis</a>
      </template>
      <button class="status-icon-btn" @click="$store.cab.openModal('settings')" title="Paramètres">⚙</button>
    </div>
  </div>

  {% include 'partials/cabinet/tab-aide.html.twig' %}

  <div class="flex-1 flex flex-col items-center justify-center text-zinc-500 dark:text-zinc-400 gap-2" x-show="!$store.cab.activeId && !$store.cab.showHelp">
    <div class="w-10 h-10 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-lg">&#128100;</div>
    <span class="text-[13px]">Sélectionnez un client</span>
    <span class="text-xs text-zinc-400 dark:text-zinc-500">ou créez un nouveau dossier</span>
  </div>

  <template x-if="$store.cab.activeId && !$store.cab.showHelp">
    <div class="flex flex-col flex-1 min-h-0">

      <div class="flex border-b border-zinc-200 dark:border-zinc-700 bg-zinc-100 dark:bg-zinc-800 overflow-x-auto max-md:[scrollbar-width:none] max-md:[&::-webkit-scrollbar]:hidden">
        <button class="hidden max-md:inline-flex items-center text-[13px] text-zinc-500 dark:text-zinc-400 cursor-pointer pl-3 pr-1 shrink-0 hover:text-zinc-700 dark:hover:text-zinc-200 leading-none"
                @click="$store.cab.goBack()" title="Retour">&#8592;</button>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='fiche' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('fiche')">Fiche client</div>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='seances' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('seances')">
          Séances (<span x-text="$store.cab.activeSessionCount"></span>)
        </div>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='bilan' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('bilan')">Bilan</div>
        <div class="px-3.5 py-2.5 text-[13px] cursor-pointer border-b-2 transition-colors whitespace-nowrap"
             :class="$store.cab.activeTab==='communication' ? 'text-primary border-primary bg-white dark:bg-zinc-900' : 'text-zinc-500 dark:text-zinc-400 border-transparent hover:text-zinc-700 dark:hover:text-zinc-200'"
             @click="$store.cab.setTab('communication')">Communication</div>
      </div>

      <div class="flex-1 overflow-y-auto p-5 max-md:p-3.5">
        {% include 'partials/cabinet/tab-fiche.html.twig' %}
        {% include 'partials/cabinet/tab-seances.html.twig' %}
        {% include 'partials/cabinet/tab-bilan.html.twig' %}
        {% include 'partials/cabinet/tab-communication.html.twig' %}
      </div>

    </div>
  </template>

</div>
