<div class="sidebar" x-data="cabinetSidebar"
  @set-sidebar-view.window="setView($event.detail)">

  <div class="sidebar-nav">
    <div class="snav" :class="{active: view==='clients' && !$store.cab.showHelp}"
         @click="$store.cab.showHelp=false; setView('clients')">Clients</div>
    <div class="snav" :class="{active: view==='agenda' && !$store.cab.showHelp}"
         @click="$store.cab.showHelp=false; setView('agenda')">Agenda</div>
    <div class="snav" :class="{active: $store.cab.showHelp}"
         @click="$store.cab.showHelp=!$store.cab.showHelp">Aide</div>
  </div>

  {# ── Clients ── #}
  <div class="sidebar-head" x-show="view==='clients'">
    <span class="sidebar-title">Clients</span>
    <div style="display:flex;gap:6px">
      <button class="btn-add" @click="$store.cab.openModal('new-client')">+ Nouveau</button>
      <button class="btn-add btn-import" @click="$store.cab.openModal('import')" title="Importer clients ou rendez-vous">&#8645; Import</button>
    </div>
  </div>

  <div id="sidebar_clients_body" x-show="view==='clients'"
       style="display:flex;flex-direction:column;flex:1;min-height:0">
    <div class="search-wrap">
      <input type="text" placeholder="Rechercher…"
             x-model="$store.cab.searchQuery"
             @input="$store.cab.currentPage=1; $store.cab.renderList()"
             autocomplete="off" autocorrect="off" autocapitalize="off"
             spellcheck="false" data-1p-ignore data-lpignore>
    </div>
    <div class="clients-browser">
      <div class="alpha-bar">
        <template x-for="item in $store.cab.alphabetLetters" :key="item.letter">
          <div class="alpha-letter"
               :class="{'alpha-selected': item.selected, 'alpha-has': item.hasClients && !item.selected, 'alpha-empty': !item.hasClients}"
               @click="item.hasClients && $store.cab.setLetter(item.letter)"
               x-text="item.letter"></div>
        </template>
      </div>
      <div class="client-list">
        <template x-for="client in $store.cab.clientList" :key="client._id">
          <div class="client-item"
               :class="{active: $store.cab.activeId === client._id}"
               @click="$store.cab.selectClient(client._id)">
            <div class="client-name" x-text="client.first_name + ' ' + client.last_name"></div>
            <div class="client-meta" x-text="client.motif || '—'"></div>
            <div class="client-badge" x-show="client._sessionCount > 0"
                 x-text="client._sessionCount + ' séance' + (client._sessionCount > 1 ? 's' : '')"></div>
          </div>
        </template>
        <div x-show="$store.cab.clientList.length === 0"
             style="padding:16px;text-align:center;font-size:12px;color:var(--cab-text-sec)">
          Aucun client
          <div x-show="$store.cab.loadState === 'error'" style="margin-top:8px;color:#a33;font-size:11px" x-text="$store.cab.loadError"></div>
          <button type="button" class="btn-verif" style="margin-top:8px" @click="$store.cab.load()">Recharger</button>
        </div>
      </div>
    </div>
    <div class="pagination" x-show="$store.cab.filteredCount > $store.cab.pageSize">
      <button class="page-btn"
              :disabled="$store.cab.currentPage <= 1"
              @click="$store.cab.goToPage($store.cab.currentPage - 1)">&#8249;</button>
      <span class="page-info" x-text="$store.cab.currentPage + ' / ' + Math.ceil($store.cab.filteredCount / $store.cab.pageSize)"></span>
      <button class="page-btn"
              :disabled="$store.cab.currentPage >= Math.ceil($store.cab.filteredCount / $store.cab.pageSize)"
              @click="$store.cab.goToPage($store.cab.currentPage + 1)">&#8250;</button>
    </div>
  </div>

  {# ── Agenda ── #}
  {% include 'partials/cabinet/sidebar-agenda.html.twig' %}


</div>
