{# ── Tableau de bord praticien ──────────────────────────────────────────────── #}
<div x-show="$store.cab.showDashboard && !$store.cab.showHelp"
     x-data="cabinetDashboard"
     class="flex-1 overflow-y-auto min-h-0">
  <div class="p-5">

    {# En-tête #}
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-[15px] font-semibold text-zinc-800 dark:text-zinc-100">Tableau de bord</h2>
      <button class="text-[12px] text-zinc-400 hover:text-primary transition-colors px-2 py-1 rounded leading-none"
              @click="$store.cab.showDashboard = false">&#215; Fermer</button>
    </div>

    {# ── KPI cards ── #}
    <div class="grid grid-cols-4 gap-3 mb-4">

      <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4">
        <div class="text-[11px] font-medium text-zinc-500 dark:text-zinc-400 mb-2">Clients</div>
        <div class="text-[28px] font-bold text-zinc-800 dark:text-zinc-100 leading-none mb-1.5" x-text="stats.totalClients"></div>
        <div class="text-[11px] font-medium text-primary" x-show="stats.newThisMonth > 0">
          +<span x-text="stats.newThisMonth"></span> ce mois
        </div>
        <div class="text-[11px] text-zinc-400 dark:text-zinc-500" x-show="stats.newThisMonth === 0">
          <span x-text="stats.activeClients"></span> actifs (90 j)
        </div>
      </div>

      <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4">
        <div class="text-[11px] font-medium text-zinc-500 dark:text-zinc-400 mb-2">Séances ce mois</div>
        <div class="text-[28px] font-bold text-zinc-800 dark:text-zinc-100 leading-none mb-1.5" x-text="stats.sessionsThisMonth"></div>
        <div class="text-[11px] font-medium"
             :class="stats.sessionsThisMonth >= stats.prevMonthSessions ? 'text-primary' : 'text-red-500'">
          <span x-text="stats.sessionsThisMonth > stats.prevMonthSessions ? '▲' : (stats.sessionsThisMonth < stats.prevMonthSessions ? '▼' : '—')"></span>
          vs <span x-text="stats.prevMonthSessions"></span> le mois passé
        </div>
      </div>

      <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4">
        <div class="text-[11px] font-medium text-zinc-500 dark:text-zinc-400 mb-2">Prochain RDV</div>
        <template x-if="stats.nextRdv">
          <div>
            <div class="text-[15px] font-semibold text-zinc-800 dark:text-zinc-100 leading-snug" x-text="formatDate(stats.nextRdv.date)"></div>
            <div class="text-[11px] text-zinc-500 dark:text-zinc-400 mt-0.5"
                 x-text="(stats.nextRdv.heure || '') + (stats.nextRdv.client_name ? ' · ' + stats.nextRdv.client_name : '')"></div>
          </div>
        </template>
        <template x-if="!stats.nextRdv">
          <div class="text-[13px] text-zinc-400 dark:text-zinc-500 pt-1">Aucun à venir</div>
        </template>
      </div>

      <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4">
        <div class="text-[11px] font-medium text-zinc-500 dark:text-zinc-400 mb-2">Total séances</div>
        <div class="text-[28px] font-bold text-zinc-800 dark:text-zinc-100 leading-none mb-1.5" x-text="stats.totalSessions"></div>
        <div class="text-[11px] text-zinc-500 dark:text-zinc-400">
          ~<span x-text="stats.totalHours"></span>h de pratique
        </div>
      </div>

    </div>

    {# ── Charts ── #}
    <div class="grid gap-3 mb-4" style="grid-template-columns:1fr 220px">

      <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4">
        <div class="text-[12px] font-medium text-zinc-700 dark:text-zinc-300 mb-3">Activité sur 12 mois</div>
        <div class="relative" style="height:175px">
          <canvas id="dash-activity-chart"></canvas>
        </div>
      </div>

      <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4">
        <div class="text-[12px] font-medium text-zinc-700 dark:text-zinc-300 mb-3">Types de séances</div>
        <div class="relative" style="height:175px">
          <canvas id="dash-type-chart"></canvas>
          <div x-show="Object.keys(_byType).length === 0"
               class="absolute inset-0 flex items-center justify-center text-[12px] text-zinc-400 dark:text-zinc-500">
            Aucune séance enregistrée
          </div>
        </div>
      </div>

    </div>

    {# ── Prochains rendez-vous ── #}
    <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4 mb-3">

      <div class="text-[12px] font-medium text-zinc-700 dark:text-zinc-300 mb-3">Prochains rendez-vous</div>

      <div x-show="upcomingAppointments.length === 0"
           class="text-[12px] text-zinc-400 dark:text-zinc-500 text-center py-4">
        Aucun rendez-vous planifié
      </div>

      <div x-show="upcomingAppointments.length > 0" class="overflow-x-auto">
        <table class="w-full text-[12px]">
          <thead>
            <tr class="text-[11px] text-zinc-500 dark:text-zinc-400 border-b border-zinc-200 dark:border-zinc-700">
              <th class="text-left pb-2 font-medium pr-4">Date</th>
              <th class="text-left pb-2 font-medium pr-4">Client</th>
              <th class="text-left pb-2 font-medium pr-4">Type</th>
              <th class="text-left pb-2 font-medium pr-4">Durée</th>
              <th class="pb-2"></th>
            </tr>
          </thead>
          <tbody>
            <template x-for="r in upcomingAppointments" :key="r.id || r.datetime">
              <tr class="border-b border-zinc-100 dark:border-zinc-700/50 last:border-0 hover:bg-white dark:hover:bg-zinc-700/40 transition-colors cursor-pointer"
                  @click="goToClient(r)">
                <td class="py-2 pr-4">
                  <div class="font-medium text-zinc-800 dark:text-zinc-200" x-text="formatDate(r.date)"></div>
                  <div class="text-[10px] text-zinc-500 dark:text-zinc-400" x-text="r.heure || ''"></div>
                </td>
                <td class="py-2 pr-4 text-zinc-700 dark:text-zinc-300 font-medium" x-text="r.client_name || '—'"></td>
                <td class="py-2 pr-4 text-zinc-500 dark:text-zinc-400" x-text="_typeLabel(r.appointment_type)"></td>
                <td class="py-2 pr-4 text-zinc-500 dark:text-zinc-400">
                  <span x-text="(r.duration || r.duree || '') ? (r.duration || r.duree) + ' min' : '—'"></span>
                </td>
                <td class="py-2">
                  <span class="inline-flex text-[10px] px-1.5 py-[2px] rounded font-medium"
                        :class="r.status === 'confirmed'
                          ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400'
                          : 'bg-zinc-200 dark:bg-zinc-700 text-zinc-500 dark:text-zinc-400'"
                        x-text="statusLabel(r.status)"></span>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>

    {# ── Derniers clients vus ── #}
    <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 p-4">

      <div class="text-[12px] font-medium text-zinc-700 dark:text-zinc-300 mb-3">Derniers clients vus</div>

      <div x-show="recentClients.length === 0"
           class="text-[12px] text-zinc-400 dark:text-zinc-500 text-center py-4">
        Aucune séance enregistrée
      </div>

      <div x-show="recentClients.length > 0" class="grid grid-cols-2 gap-2">
        <template x-for="c in recentClients" :key="c.id">
          <div class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-white dark:bg-zinc-900 border border-zinc-100 dark:border-zinc-700 cursor-pointer hover:border-zinc-300 dark:hover:border-zinc-500 transition-colors"
               @click="$store.cab.showDashboard = false; $store.cab.selectClient(c.id)">
            <div class="min-w-0">
              <div class="text-[12px] font-medium text-zinc-800 dark:text-zinc-200 truncate" x-text="c.name"></div>
              <div class="text-[11px] text-zinc-500 dark:text-zinc-400" x-text="'Vu le ' + formatDate(c.lastDate)"></div>
            </div>
            <div class="text-right shrink-0 ml-3">
              <div class="text-[18px] font-bold text-primary leading-none" x-text="c.sessionCount"></div>
              <div class="text-[10px] text-zinc-400 dark:text-zinc-500">séances</div>
            </div>
          </div>
        </template>
      </div>

    </div>

  </div>
</div>
