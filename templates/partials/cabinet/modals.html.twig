<div class="fixed inset-0 bg-black/45 dark:bg-black/65 flex items-center justify-center z-[100] backdrop-blur-[2px] max-md:items-end"
     x-data
     x-show="$store.cab.modal.open"
     @click.self="$store.cab.closeModal()"
     style="display:none">
  <div class="bg-white dark:bg-zinc-900 rounded-xl border border-zinc-200 dark:border-zinc-700 p-[22px] w-[560px] max-w-[92vw] max-h-[88vh] overflow-y-auto shadow-[0_8px_32px_rgba(0,0,0,.18)] max-md:w-full max-md:max-w-full max-md:max-h-[90dvh] max-md:rounded-t-2xl max-md:rounded-b-none max-md:border-none max-md:m-0">

    {# ── Nouveau client ── #}
    <div x-show="$store.cab.modal.type==='new-client'" x-data="cabinetNewClientModal">
      <div class="flex justify-between items-center mb-4">
        <span class="text-[15px] font-semibold">Nouveau client</span>
        <button class="bg-transparent border-none text-[18px] cursor-pointer text-zinc-500 dark:text-zinc-400 leading-none hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors" @click="$store.cab.closeModal()">&#215;</button>
      </div>
      <div class="field-grid">
        <div class="field"><label>Prénom *</label><input x-model="form.first_name" @keyup.enter="submit()"></div>
        <div class="field"><label>Nom *</label><input x-model="form.last_name" @keyup.enter="submit()"></div>
        <div class="field"><label>Téléphone</label><input x-model="form.phone"></div>
        <div class="field"><label>Email</label><input x-model="form.email"></div>
        <div class="field field-full"><label>Motif principal</label><input x-model="form.motif"></div>
      </div>
      <button class="btn-save" @click="submit()">Créer le dossier</button>
    </div>

    {# ── Séance (nouvelle / modification) ── #}
    <div x-show="$store.cab.modal.type==='session'" x-data="cabinetSessionModal">
      <div class="flex justify-between items-center mb-4">
        <span class="text-[15px] font-semibold" x-text="isEdit ? 'Modifier la séance' : 'Nouvelle séance'"></span>
        <button class="bg-transparent border-none text-[18px] cursor-pointer text-zinc-500 dark:text-zinc-400 leading-none hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors" @click="$store.cab.closeModal()">&#215;</button>
      </div>

      <div class="flex mb-[18px] border border-zinc-200 dark:border-zinc-700 rounded-lg overflow-hidden">
        <div class="flex-1 text-center px-3.5 py-1.5 text-[12px] cursor-pointer transition-colors"
             :class="modalTab==='clinique' ? 'bg-primary text-white' : 'text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700'"
             @click="modalTab='clinique'">Clinique</div>
        <div class="flex-1 text-center px-3.5 py-1.5 text-[12px] cursor-pointer transition-colors"
             :class="modalTab==='energetique' ? 'bg-primary text-white' : 'text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700'"
             @click="modalTab='energetique'">Bilan</div>
      </div>

      <div x-show="modalTab==='clinique'">
        <div class="field-grid">
          <div class="field"><label>Date</label><input type="date" x-model="form.date"></div>
          <div class="field"><label>Heure</label><input type="time" x-model="form.heure"></div>
          <div class="field"><label>Durée (min)</label><input type="number" x-model="form.duree" min="1" step="5" placeholder="60"></div>
          <div class="field">
            <label>Statut</label>
            <select x-model="form.status">
              <template x-for="opt in statusOpts()" :key="opt[0]">
                <option :value="opt[0]" x-text="opt[1]"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label>Type</label>
            <select x-model="form.appointment_type">
              <template x-for="opt in typeOpts()" :key="opt[0]">
                <option :value="opt[0]" x-text="opt[1]"></option>
              </template>
            </select>
          </div>
          <div class="field field-full">
            <label>Motif de la séance</label>
            <input x-model="form.motif" placeholder="ex: douleur lombaire, stress...">
          </div>
          <div class="field field-full">
            <label>Observations cliniques</label>
            <textarea x-model="form.observations" placeholder="Zones travaillées, réactions, état général..."></textarea>
          </div>
          <div class="field field-full">
            <label>Exercices transmis (séparés par virgule)</label>
            <input x-model="form.exercices" placeholder="ex: étirement mollet, auto-massage balle">
          </div>
          <div class="field field-full">
            <label>Intention pour la prochaine séance</label>
            <input x-model="form.prochaine">
          </div>
          <div class="field field-full mt-1" x-show="smsEnabled">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" x-model="form.sms_rappel_disabled">
              Désactiver le rappel SMS J-1 pour cette séance
            </label>
          </div>
        </div>
      </div>

      <div x-show="modalTab==='energetique'">
        <div class="internal-badge">Usage interne — non communiqué au client</div>
        <div class="section-label">État des méridiens</div>
        <div class="grid grid-cols-3 gap-2 mb-3 max-md:grid-cols-2">
          <template x-for="m in meridians()" :key="m.id">
            <div class="border border-zinc-200 dark:border-zinc-700 rounded-lg p-2 bg-zinc-100 dark:bg-zinc-800">
              <div class="text-[11px] font-medium mb-1" x-text="m.name"></div>
              <select class="w-full text-[11px] px-[5px] py-[3px] rounded border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-700 dark:text-zinc-200 font-[inherit] outline-none"
                      x-model="bilan[m.id]">
                <template x-for="st in meridianStates()" :key="st.val">
                  <option :value="st.val" x-text="st.label"></option>
                </template>
              </select>
            </div>
          </template>
        </div>
        <div class="field-grid">
          <div class="field">
            <label>Élément dominant</label>
            <select x-model="bilan.element_dominant">
              <template x-for="el in elementOpts()" :key="el">
                <option :value="el" x-text="el || '—'"></option>
              </template>
            </select>
          </div>
          <div class="field">
            <label>Évolution vs séance précédente</label>
            <input x-model="bilan.evolution" placeholder="Amélioration, stagnation...">
          </div>
          <div class="field field-full">
            <label>Synthèse MTC</label>
            <textarea x-model="bilan.synthese_mtc" placeholder="Lecture énergétique globale, déséquilibres principaux..."></textarea>
          </div>
          <div class="field field-full">
            <label>Points / zones travaillés</label>
            <textarea x-model="bilan.prise_en_charge" placeholder="Points utilisés, techniques appliquées..."></textarea>
          </div>
        </div>
      </div>

      <button class="btn-save" @click="submit()"
              x-text="isEdit ? 'Mettre à jour' : 'Enregistrer la séance'"></button>
    </div>

    {# ── Paramètres praticien ── #}
    <div x-show="$store.cab.modal.type==='settings'" x-data="cabinetSettingsModal">
      <div class="flex justify-between items-center mb-3">
        <span class="text-[15px] font-semibold">Paramètres</span>
        <button class="bg-transparent border-none text-[18px] cursor-pointer text-zinc-500 dark:text-zinc-400 leading-none hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors" @click="$store.cab.closeModal()">&#215;</button>
      </div>

      {# Onglets #}
      <div class="flex mb-4 border border-zinc-200 dark:border-zinc-700 rounded-lg overflow-hidden text-[11px]">
        <template x-for="t in [{id:'praticien',label:'Praticien'},{id:'connexions',label:'Google'},{id:'communications',label:'Comms'},{id:'page_prep',label:'Page accueil'},{id:'systeme',label:'Système'}]" :key="t.id">
          <div class="flex-1 text-center px-2 py-1.5 cursor-pointer transition-colors"
               :class="tab===t.id ? 'bg-primary text-white font-semibold' : 'text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700'"
               @click="tab=t.id" x-text="t.label"></div>
        </template>
      </div>

      <div x-show="loading" class="text-center py-6 text-zinc-400 text-[13px]">Chargement…</div>

      {# ── Onglet Praticien ── #}
      <div x-show="!loading && tab==='praticien'">
        <div class="field-grid">
          <div class="field"><label>Nom affiché</label><input x-model="form.practitioner_name" placeholder="Prénom Nom"></div>
          <div class="field"><label>Titre / spécialité</label><input x-model="form.practitioner_title" placeholder="Praticien Shiatsu…"></div>
          <div class="field"><label>Téléphone</label><input x-model="form.practitioner_phone" placeholder="06 XX XX XX XX"></div>
          <div class="field"><label>Prix 1ʳᵉ séance (€)</label><input type="number" x-model="form.practitioner_first_session_price" min="0" step="1"></div>
          <div class="field field-full"><label>Site web</label><input x-model="form.practitioner_website" placeholder="https://…"></div>
          <div class="field field-full"><label>URL prise de RDV</label><input x-model="form.practitioner_booking_url" placeholder="https://resalib.fr/…"></div>
          <div class="field field-full"><label>Adresse (rue)</label><input x-model="form.practitioner_address_street" placeholder="1 rue de la Paix"></div>
          <div class="field field-full"><label>Adresse (complément)</label><input x-model="form.practitioner_address_details" placeholder="Bât A, porte de gauche…"></div>
          <div class="field"><label>Ville / code postal</label><input x-model="form.practitioner_address_city" placeholder="75001 Paris"></div>
          <div class="field"><label>Code d'accès</label><input x-model="form.practitioner_access_code" placeholder="1234A"></div>
        </div>
      </div>

      {# ── Onglet Google ── #}
      <div x-show="!loading && tab==='connexions'">
        <div class="field-grid">
          <div class="field field-full">
            <label>Google OAuth2 Client ID</label>
            <input x-model="form.google_oauth_client_id" placeholder="xxxx.apps.googleusercontent.com">
            <span class="field-hint">Google Cloud Console → APIs → Drive API → Identifiants → Client OAuth 2.0.<br>Origine autorisée : <strong>{{ base_url_absolute }}</strong></span>
          </div>
          <div class="field field-full">
            <label>Identifiant du calendrier Google</label>
            <input x-model="form.google_calendar_id" placeholder="xxxx@group.calendar.google.com">
            <span class="field-hint">Paramètres du calendrier → « Adresse de l'agenda ». Laisser vide pour désactiver.</span>
          </div>
          <div class="field field-full">
            <label>Chemin Drive (dossier bilans)</label>
            <input x-model="form.drive_bilan_path" placeholder="Mon Drive/clients">
            <span class="field-hint">Chemin relatif dans votre Google Drive vers le dossier contenant les bilans PDF clients.</span>
          </div>
        </div>
      </div>

      {# ── Onglet Communications ── #}
      <div x-show="!loading && tab==='communications'">
        <div class="field-grid">
          <div class="field field-full">
            <label>URL avis Google</label>
            <input x-model="form.communication_google_review_url" placeholder="https://g.page/r/…/review">
          </div>
          <div class="field field-full">
            <label>Template SMS préparation visite</label>
            <textarea rows="4" x-model="form.communication_template_prep_visite" placeholder="Bonjour {{first_name}},&#10;&#10;Afin de préparer notre première séance…"></textarea>
            <span class="field-hint">Variables : <code>{{first_name}}</code> <code>{{session_slot}}</code> <code>{{preparation_link}}</code> <code>{{duration}}</code></span>
          </div>
          <div class="field field-full">
            <label>Template SMS compte-rendu</label>
            <textarea rows="3" x-model="form.communication_template_compte_rendu" placeholder="Bonjour {{first_name}},&#10;&#10;Merci pour votre confiance…"></textarea>
            <span class="field-hint">Variables : <code>{{first_name}}</code> <code>{{session_date_label}}</code> <code>{{google_review_url}}</code></span>
          </div>
          <div class="field field-full">
            <label>Template relance</label>
            <textarea rows="3" x-model="form.communication_template_relance" placeholder="Bonjour {{first_name}},…"></textarea>
          </div>
        </div>
      </div>

      {# ── Onglet Page accueil / préparation ── #}
      <div x-show="!loading && tab==='page_prep'">
        <p class="text-[12px] text-zinc-500 dark:text-zinc-400 mb-2">
          Rédigez la page complète en <strong>Markdown</strong>. Les <code>{{variables}}</code> sont remplacées automatiquement par les données du client et du rendez-vous. Laissez vide pour utiliser le rendu automatique.
        </p>
        <details class="mb-3 text-[11px] border border-zinc-200 dark:border-zinc-700 rounded-lg">
          <summary class="px-3 py-1.5 cursor-pointer text-zinc-500 dark:text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200 select-none">Variables disponibles</summary>
          <div class="px-3 pb-2.5 pt-1 grid grid-cols-2 gap-x-4 gap-y-0.5">
            <span><code>{{first_name}}</code> – prénom</span>
            <span><code>{{last_name}}</code> – nom</span>
            <span><code>{{appointment_date}}</code> – date RDV</span>
            <span><code>{{appointment_time}}</code> – heure RDV</span>
            <span><code>{{appointment_type}}</code> – type séance</span>
            <span><code>{{duration}}</code> – durée (min)</span>
            <span><code>{{price}}</code> – tarif 1ʳᵉ séance</span>
            <span><code>{{pract_name}}</code> – votre nom</span>
            <span><code>{{pract_phone}}</code> – votre téléphone</span>
            <span><code>{{pract_website}}</code> – votre site web</span>
            <span><code>{{booking_url}}</code> – lien prise de RDV</span>
            <span><code>{{address_street}}</code> – rue</span>
            <span><code>{{address_city}}</code> – ville</span>
            <span><code>{{address}}</code> – adresse complète</span>
            <span><code>{{access_code}}</code> – code d'accès</span>
          </div>
        </details>
        <div class="field-grid">
          <div class="field field-full">
            <label>Contenu de la page</label>
            <textarea rows="18" x-model="form.prep_page_content" class="font-mono text-[11px]"
              placeholder="Bonjour {{first_name}},&#10;&#10;Je suis ravi de vous accueillir le **{{appointment_date}}** à **{{appointment_time}}**.&#10;&#10;## 📍 Adresse&#10;&#10;**{{address_street}}**  &#10;{{address_city}} — code : **{{access_code}}**&#10;&#10;…"></textarea>
            <span class="field-hint">Markdown standard — titres avec <code>##</code>, gras avec <code>**…**</code>, listes avec <code>-</code>, liens <code>[texte](url)</code>.</span>
          </div>
          <div class="field field-full">
            <label>Mention de pied de page</label>
            <input x-model="form.prep_page_footer"
              placeholder="Cette approche ne se substitue pas à un traitement médical.">
          </div>
        </div>
      </div>

      {# ── Onglet Système ── #}
      <div x-show="!loading && tab==='systeme'">
        <div class="field-grid">
          <div class="field field-full">
            <label class="flex items-center gap-2 cursor-pointer select-none">
              <button type="button" role="switch" :aria-checked="form.sms_enabled" @click="form.sms_enabled=!form.sms_enabled"
                      class="relative inline-flex items-center w-11 h-6 rounded-full border-none p-[2px] transition-colors shrink-0 cursor-pointer focus:outline-2 focus:outline-offset-2 focus:outline-primary"
                      :class="form.sms_enabled ? 'bg-primary' : 'bg-zinc-300 dark:bg-zinc-600'">
                <span class="w-5 h-5 rounded-full bg-white shadow-[0_1px_3px_rgba(0,0,0,.25)] transition-transform"
                      :class="form.sms_enabled ? 'translate-x-5' : 'translate-x-0'"></span>
              </button>
              <span class="text-[13px]">Rappels SMS activés</span>
            </label>
          </div>
          <div class="field">
            <label>Clients par page</label>
            <input type="number" x-model.number="pageSize" min="5" max="100" step="1">
            <span class="field-hint">Nombre de clients affichés par page (5–100).</span>
          </div>
          <div class="field field-full">
            <label>Clé API (accès externe)</label>
            <div class="flex gap-2 items-center">
              <input class="flex-1 font-mono text-[11px]"
                     :value="apiKeyVisible ? apiKeyFull : apiKeyMasked"
                     :placeholder="hasApiKey ? '' : 'Aucune clé — cliquez Générer'"
                     readonly>
              <button type="button" class="shrink-0 px-2.5 py-1.5 rounded-lg border border-zinc-300 dark:border-zinc-600 text-[11px] text-zinc-600 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
                      x-show="hasApiKey && apiKeyFull"
                      @click="toggleKeyVisibility()"
                      x-text="apiKeyVisible ? 'Masquer' : 'Afficher'"></button>
            </div>
            <span class="field-hint">Utilisée dans l'en-tête <code>X-Api-Key</code> pour les appels scripts / cron / Make.com.</span>
          </div>
          <div class="field field-full">
            <button type="button"
                    class="px-3.5 py-1.5 rounded-lg border border-zinc-300 dark:border-zinc-600 text-[12px] text-zinc-700 dark:text-zinc-200 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
                    @click="regenerateApiKey()">
              {{ hasApiKey ? 'Regénérer la clé API' : 'Générer une clé API' }}
            </button>
            <span class="field-hint mt-1 block text-amber-600 dark:text-amber-400">⚠ Toute ancienne clé sera immédiatement invalidée.</span>
          </div>
        </div>
      </div>

      <button class="btn-save mt-4" @click="save()" :disabled="saving || loading"
              x-text="saving ? 'Enregistrement…' : 'Enregistrer'"></button>
    </div>

    {# ── Import données ── #}
    <div x-show="$store.cab.modal.type==='import'" x-data="cabinetImportModal">
      <div class="flex justify-between items-center mb-4">
        <span class="text-[15px] font-semibold">Import données</span>
        <button class="bg-transparent border-none text-[18px] cursor-pointer text-zinc-500 dark:text-zinc-400 leading-none hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors" @click="$store.cab.closeModal()">&#215;</button>
      </div>
      <div class="flex mb-[18px] border border-zinc-200 dark:border-zinc-700 rounded-lg overflow-hidden">
        <div class="flex-1 text-center px-3.5 py-1.5 text-[12px] cursor-pointer transition-colors"
             :class="tab==='clients' ? 'bg-primary text-white' : 'text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700'"
             @click="switchTab('clients')">Clients (CSV)</div>
        <div class="flex-1 text-center px-3.5 py-1.5 text-[12px] cursor-pointer transition-colors"
             :class="tab==='rendezvous' ? 'bg-primary text-white' : 'text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700'"
             @click="switchTab('rendezvous')">Rendez-vous (ICS)</div>
      </div>
      <div class="field-grid">
        <div class="field field-full">
          <label x-text="tab === 'clients' ? 'Fichier CSV' : 'Fichier ICS'"></label>
          <input type="file" :accept="tab === 'clients' ? '.csv,text/csv' : '.ics,text/calendar'" @change="onFile($event)">
          <span class="field-hint" x-show="tab === 'clients'">Colonnes : email, prenom, nom — optionnelles : telephone, code_postal</span>
          <span class="field-hint" x-show="tab === 'rendezvous'">Export Google Calendar / Resalib.fr (.ics)</span>
        </div>
        <div class="field field-full">
          <label class="flex items-center gap-[10px] cursor-pointer select-none">
            <button type="button" role="switch" :aria-checked="dryRun" @click="dryRun = !dryRun"
                    class="relative inline-flex items-center w-11 h-6 rounded-full border-none p-[2px] transition-colors shrink-0 cursor-pointer focus:outline-2 focus:outline-offset-2 focus:outline-primary"
                    :class="dryRun ? 'bg-yellow-500' : 'bg-zinc-300 dark:bg-zinc-600'">
              <span class="w-5 h-5 rounded-full bg-white shadow-[0_1px_3px_rgba(0,0,0,.25)] transition-transform"
                    :class="dryRun ? 'translate-x-5' : 'translate-x-0'"></span>
            </button>
            <span class="text-[13px] text-zinc-500 dark:text-zinc-400"
                  x-text="dryRun ? 'Simulation — aucune donnée modifiée' : 'Import réel — les données seront modifiées'"></span>
          </label>
        </div>
      </div>
      <button class="btn-save" :disabled="running || !file"
              @click="run()"
              x-text="running ? 'En cours…' : (dryRun ? 'Simuler' : 'Importer')"></button>
      <div x-show="result" class="mt-3.5">
        <div class="flex gap-3 flex-wrap text-[12px] font-semibold mb-2" x-show="result?.stats">
          <span class="imp-create" x-text="'Créés : '      + (result?.stats?.created ?? 0)"></span>
          <span class="imp-update" x-text="'Mis à jour : ' + (result?.stats?.updated ?? 0)"></span>
          <span class="imp-skip"   x-text="'Ignorés : '    + (result?.stats?.skipped ?? 0)"></span>
          <span class="imp-error"  x-text="'Erreurs : '    + (result?.stats?.errors  ?? 0)"></span>
          <span x-show="result?.dry_run" class="italic text-zinc-500 dark:text-zinc-400">(simulation)</span>
        </div>
        <div class="text-[11px] max-h-[220px] overflow-y-auto border border-zinc-200 dark:border-zinc-700 rounded-md font-mono">
          <template x-for="(entry, i) in (result?.log || [])" :key="i">
            <div class="flex gap-2 px-2 py-[3px] border-b border-zinc-200 dark:border-zinc-700 last:border-b-0"
                 :class="actionClass(entry.action)">
              <span class="font-bold min-w-[52px] shrink-0" x-text="entry.action"></span>
              <span x-text="entry.msg"></span>
            </div>
          </template>
        </div>
      </div>
    </div>

    {# ── Vérification globale ── #}
    <div x-show="$store.cab.modal.type==='verif'" x-data>
      <div class="flex justify-between items-center mb-4">
        <span class="text-[15px] font-semibold">Vérification globale</span>
        <button class="bg-transparent border-none text-[18px] cursor-pointer text-zinc-500 dark:text-zinc-400 leading-none hover:text-zinc-700 dark:hover:text-zinc-200 transition-colors" @click="$store.cab.closeModal()">&#215;</button>
      </div>
      <div class="text-[12px] leading-[1.9] max-h-[360px] overflow-y-auto font-mono bg-zinc-100 dark:bg-zinc-800 px-3.5 py-3 rounded-lg mb-3 border border-zinc-200 dark:border-zinc-700">
        <template x-for="(entry, i) in $store.cab.modal.verifLog" :key="i">
          <div class="text-zinc-500 dark:text-zinc-400"
               :class="entry.type ? 'verif-' + entry.type : ''"
               x-html="entry.msg"></div>
        </template>
      </div>
      <div class="text-[12px] text-zinc-500 dark:text-zinc-400 pt-[2px]"
           :class="$store.cab.modal.verifDone
             ? ($store.cab.modal.verifSummary?.ok ? 'verif-footer-ok' : 'verif-footer-warn')
             : ''"
           x-text="$store.cab.modal.verifDone
             ? ($store.cab.modal.verifSummary?.text || '')
             : 'En cours…'">
      </div>
    </div>

  </div>
</div>
