{% extends 'partials/base.html.twig' %}

{% set cab_ver = '20260422-01' %}
{% set route_app = app.plugins.cabinet.route_app_base ?? '/cabinet' %}

{% block stylesheets %}
  {{ parent() }}
  {% do assets.addCss(route_app ~ '/cabinet.css?v=' ~ cab_ver, {priority: 5}) %}
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  {% do assets.addJs('https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js', {group: 'bottom', priority: 25}) %}
  {% do assets.addJs('https://apis.google.com/js/api.js', {group: 'head', loading: 'defer'}) %}
  {% do assets.addJs('https://accounts.google.com/gsi/client', {group: 'head', loading: 'async'}) %}
  {# utils — chargés en premier, pas de dépendances entre eux #}
  {% do assets.addJs(route_app ~ '/utils/constants.js?v=' ~ cab_ver, {group: 'bottom', priority: 22}) %}
  {% do assets.addJs(route_app ~ '/utils/helpers.js?v=' ~ cab_ver,   {group: 'bottom', priority: 20}) %}
  {% do assets.addJs(route_app ~ '/utils/toast.js?v=' ~ cab_ver,     {group: 'bottom', priority: 18}) %}
  {% do assets.addJs(route_app ~ '/utils/api.js?v=' ~ cab_ver,       {group: 'bottom', priority: 17}) %}
  {% do assets.addJs(route_app ~ '/utils/sms.js?v=' ~ cab_ver,       {group: 'bottom', priority: 16}) %}
  {# drive — dépend des utils #}
  {% do assets.addJs(route_app ~ '/cab-drive.js?v=' ~ cab_ver,       {group: 'bottom', priority: 14}) %}
  {# store — dépend de tout ce qui précède #}
  {% do assets.addJs(route_app ~ '/store/index.js?v=' ~ cab_ver,     {group: 'bottom', priority: 12}) %}
  {# components — chacun définit une factory function globale #}
  {% do assets.addJs(route_app ~ '/components/toast.js?v=' ~ cab_ver,     {group: 'bottom', priority: 9}) %}
  {% do assets.addJs(route_app ~ '/components/sidebar.js?v=' ~ cab_ver,   {group: 'bottom', priority: 8}) %}
  {% do assets.addJs(route_app ~ '/components/modal.js?v=' ~ cab_ver,     {group: 'bottom', priority: 7}) %}
  {% do assets.addJs(route_app ~ '/components/accordion.js?v=' ~ cab_ver, {group: 'bottom', priority: 6}) %}
  {% do assets.addJs(route_app ~ '/components/drive-bar.js?v=' ~ cab_ver, {group: 'bottom', priority: 6}) %}
  {% do assets.addJs(route_app ~ '/components/dashboard.js?v=' ~ cab_ver, {group: 'bottom', priority: 6}) %}
  {# main — point d'entrée Alpine, enregistre tout #}
  {% do assets.addJs(route_app ~ '/main.js?v=' ~ cab_ver,            {group: 'bottom', priority: 5}) %}
{% endblock %}

{% block body %}
<section class="flex flex-col flex-1 {{ header_fixed ? 'pt-16' : '' }} overflow-hidden">
  <div class="flex items-stretch flex-1 p-0 overflow-hidden">
    <div class="grid grid-cols-[260px_1fr] w-full overflow-hidden bg-white dark:bg-zinc-900 h-full min-h-0 max-md:grid-cols-1 max-md:border-x-0 max-md:border-b-0 max-md:min-h-[calc(100dvh-8rem)] max-md:h-auto" id="app" x-data>
      {% include 'partials/cabinet/sidebar.html.twig' %}
      {% include 'partials/cabinet/main.html.twig' %}
    </div>
  </div>
</section>

<div class="cab-toast-stack" x-data="cabToast">
  <template x-for="t in toasts" :key="t.id">
    <div class="cab-toast" :class="t.type==='error' ? 'is-error' : 'is-success'" x-text="t.message"></div>
  </template>
</div>

{% include 'partials/cabinet/modals.html.twig' %}

<script>
  window.CABINET_SITE_URL = '{{ base_url_absolute|raw }}';
  window.CABINET_ROUTE_APP = '{{ app.plugins.cabinet.route_app_base ?? '/cabinet' }}';
  window.CABINET_ROUTE_API = '{{ app.plugins.cabinet.route_api_base ?? '/api/cabinet' }}';
</script>
<script>
  if('serviceWorker' in navigator)
    navigator.serviceWorker.register('{{ app.plugins.cabinet.route_app_base ?? '/cabinet' }}/sw.js?v={{ cab_ver }}').catch(()=>{});
</script>
{% endblock %}
